# Docker host paths
HOST_SOURCE_IMAGE_DIR=./sample-images

# Application paths and sources inside the app container
SOURCE_IMAGE_DIR=/images
IMAGE_SOURCES=
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tif,.tiff,.gif
THUMBNAIL_DIR=/app/data/thumbnails
UPLOAD_DIR=/app/data/uploads
GIF_SAMPLE_FRAMES=16
GIF_MAX_DECODE_FRAMES=512
GIF_PREVIEW_FRAMES=16
GIF_DEFAULT_FRAME_DELAY_MS=100
GIF_MOTION_WEIGHT=0.2

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=image_similarity
VECTOR_SIZE=512

# Embeddings. The native Rust service currently uses a deterministic image-vector embedder.
CLIP_MODEL_NAME=sentence-transformers/clip-ViT-B-32

# API behavior
DEFAULT_SEARCH_LIMIT=12
DUPLICATE_HASH_DISTANCE=8
MAX_UPLOAD_MB=20

# Development dummy data
DUMMY_DATA_DIR=/seed/local
DUMMY_IMAGE_COUNT=8
DUMMY_IMAGE_SIZE=640x480
DUMMY_IMAGE_FORMAT=JPEG
DUMMY_GIF_FRAMES=6
DUMMY_GIF_FRAME_DELAY_MS=100
