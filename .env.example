# Docker host paths
HOST_PICTURES_DIR=${HOME}/Pictures
HOST_VIDEO_DIR=${HOME}/Videos
HOST_AUDIO_DIR=${HOME}/Music

# Application paths and sources inside the app container
SOURCE_IMAGE_DIR=/images
MEDIA_SOURCES_FILE=/app/config/media-sources.txt
IMAGE_SOURCES=
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tif,.tiff,.gif
AUDIO_EXTENSIONS=.mp3,.wav,.flac,.m4a,.aac,.ogg,.opus
AUDIO_TRANSCRIPTION_ENABLED=false
AUDIO_TRANSCRIPTION_MODEL=base.en
AUDIO_TRANSCRIPTION_LANGUAGE=en
AUDIO_TRANSCRIPTION_THREADS=
AUDIO_TRANSCRIPTION_AUTO_DOWNLOAD=false
AUDIO_TRANSCRIPTION_CACHE_DIR=
THUMBNAIL_DIR=/app/data/thumbnails
UPLOAD_DIR=/app/data/uploads
VOICE_REGISTRY_PATH=/app/data/recognized-voices.json
VIDEO_FRAME_STRIDE=30
VIDEO_MAX_FRAMES=
GIF_SAMPLE_FRAMES=16
GIF_MAX_DECODE_FRAMES=512
GIF_PREVIEW_FRAMES=16
GIF_DEFAULT_FRAME_DELAY_MS=100
GIF_MOTION_WEIGHT=0.2
OCR_ENABLED=true
OCR_COMMAND=tesseract
OCR_LANGUAGE=eng
OCR_MAX_FRAMES=4

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=image_similarity
VECTOR_SIZE=512

# Embeddings. The native Rust service currently uses a deterministic image-vector embedder.
CLIP_MODEL_NAME=sentence-transformers/clip-ViT-B-32

# API behavior
DEFAULT_SEARCH_LIMIT=12
DUPLICATE_HASH_DISTANCE=8
MAX_UPLOAD_MB=20
BIND_ADDR=0.0.0.0:8000

# Development sample data
SAMPLE_FACE_HOST_DIR=./sample-images
SAMPLE_FACE_DATA_DIR=/seed/local
SAMPLE_FACE_COUNT=150
SAMPLE_FACE_URL=https://thispersondoesnotexist.com/
SAMPLE_FACE_DELAY_MS=1000
SAMPLE_FACE_MAX_ATTEMPTS=750
SAMPLE_FACE_CLEAR_GENERATED=true
