# Docker host paths
HOST_SOURCE_IMAGE_DIR=./sample-images

# Application paths and sources inside the app container
SOURCE_IMAGE_DIR=/images
IMAGE_SOURCES=
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tif,.tiff
THUMBNAIL_DIR=/app/data/thumbnails
UPLOAD_DIR=/app/data/uploads

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=image_similarity
RUST_QDRANT_COLLECTION=image_similarity_rust
TEST_QDRANT_COLLECTION=image_similarity_test
VECTOR_SIZE=512

# Embeddings
CLIP_MODEL_NAME=sentence-transformers/clip-ViT-B-32

# MinIO source support and compose service credentials
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=image-similarity-dev
MINIO_PREFIX=catalog
MINIO_CONSOLE_PORT=9001

# Video and camera sources
VIDEO_FRAME_STRIDE=30
VIDEO_MAX_FRAMES=
CAMERA_FRAME_STRIDE=30
CAMERA_MAX_FRAMES=100

# API behavior
DEFAULT_SEARCH_LIMIT=12
DUPLICATE_HASH_DISTANCE=8
MAX_UPLOAD_MB=20

# Development dummy data
DUMMY_DATA_DIR=/seed/local
DUMMY_IMAGE_COUNT=8
DUMMY_IMAGE_SIZE=640x480
DUMMY_IMAGE_FORMAT=JPEG
SEED_MINIO=true
MINIO_WAIT_SECONDS=60
